# CampaignMasta environment configuration (copy to .env for local prod-like runs).
# All variables are optional in DEBUG mode; required ones are noted for production.

# ── Core ───────────────────────────────────────────────────────────────────────
DJANGO_DEBUG=false
# REQUIRED in production. Generate with: python -c "import secrets;print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-value
DJANGO_ALLOWED_HOSTS=campaign.webmasta.com.pg,www.campaign.webmasta.com.pg
DJANGO_CSRF_TRUSTED_ORIGINS=https://campaign.webmasta.com.pg,https://www.campaign.webmasta.com.pg
DJANGO_LOG_LEVEL=INFO

# ── HTTPS / security (defaults are secure when DEBUG=false) ─────────────────────
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_HSTS_SECONDS=31536000

# ── Database (omit all to use the bundled SQLite database) ─────────────────────
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=campaignmasta
# DB_USER=campaignmasta
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# ── Storage paths ──────────────────────────────────────────────────────────────
# MEDIA_ROOT=/app/media

# ── Gunicorn / container ───────────────────────────────────────────────────────
PORT=8031
WEB_CONCURRENCY=3
GUNICORN_TIMEOUT=60
# Set to 1 to run seed_demo on container start (first deploy / demos only).
SEED_DEMO=0
