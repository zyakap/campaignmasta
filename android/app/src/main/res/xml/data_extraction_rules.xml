<?xml version="1.0" encoding="utf-8"?>
<!--
    Exclude all campaign data from Android cloud backup and device-to-device transfer.
    Campaign data is sensitive and must not be backed up to user's Google account.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
